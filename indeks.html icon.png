<!DOCTYPE html>
<html lang="tr">
<head>
 <img src="icon.png" style="
  width:120px;
  height:120px;
  object-fit:cover;
  border-radius:20px;
  display:block;
  margin:20px auto;
  box-shadow:0 4px 10px rgba(0,0,0,0.2);
">

<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<link rel="apple-touch-icon" href="icon.png">
<meta charset="UTF-8">
<title>Kalori Takip Pro+</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body{
  background:#0f172a;
  color:white;
  font-family:sans-serif;
  text-align:center;
  padding:20px;
}

h1{
  font-size:28px;
}

input{
  padding:12px;
  border-radius:10px;
  border:none;
  margin:5px;
  width:40%;
}

button{
  padding:12px 20px;
  border:none;
  border-radius:10px;
  background:#22c55e;
  color:white;
  font-size:16px;
}

.card{
  background:#1e293b;
  margin-top:20px;
  padding:15px;
  border-radius:15px;
}

.item{
  background:#334155;
  margin:5px;
  padding:10px;
  border-radius:10px;
  display:flex;
  justify-content:space-between;
}
</style>
</head>

<body>

<h1>🔥 Kalori Takip Pro+</h1>

<input id="yemek" placeholder="Yemek">
<input id="kalori" type="number" placeholder="Kalori"><br>
<button onclick="ekle()">Ekle</button>

<div class="card">
🎯 Hedef: <input id="hedef" type="number" value="2000" onchange="kaydet()">
<h2 id="toplam">Toplam: 0 kcal</h2>
</div>

<canvas id="grafik"></canvas>

<div class="card">
<h3>📅 Geçmiş</h3>
<select id="gunler" onchange="gunDegistir()"></select>
<div id="liste"></div>
</div>

<script>
let veri = JSON.parse(localStorage.getItem("kalori")) || {}

let bugun = new Date().toISOString().split("T")[0]

if(!veri[bugun]){
  veri[bugun] = { yemekler:[], hedef:2000 }
}

function kaydet(){
  localStorage.setItem("kalori", JSON.stringify(veri))
}

function ekle(){
  let yemek = document.getElementById("yemek").value
  let kalori = Number(document.getElementById("kalori").value)

  if(!yemek || !kalori) return

  veri[bugun].yemekler.push({yemek,kalori})

  kaydet()
  guncelle()
}

function sil(i){
  veri[bugun].yemekler.splice(i,1)
  kaydet()
  guncelle()
}

function guncelle(){
  let liste = document.getElementById("liste")
  liste.innerHTML=""

  let toplam=0

  veri[bugun].yemekler.forEach((x,i)=>{
    toplam+=x.kalori
    liste.innerHTML+=`
    <div class="item">
      ${x.yemek} - ${x.kalori} kcal
      <button onclick="sil(${i})">X</button>
    </div>`
  })

  document.getElementById("toplam").innerText="Toplam: "+toplam+" kcal"

  grafikCiz(toplam)
  gunleriDoldur()
}

function grafikCiz(toplam){
  let hedef = veri[bugun].hedef

  new Chart(document.getElementById("grafik"),{
    type:"doughnut",
    data:{
      labels:["Alınan","Kalan"],
      datasets:[{
        data:[toplam, hedef-toplam]
      }]
    }
  })
}

function gunleriDoldur(){
  let select = document.getElementById("gunler")
  select.innerHTML=""

  Object.keys(veri).reverse().forEach(g=>{
    select.innerHTML+=`<option>${g}</option>`
  })
}

function gunDegistir(){
  bugun = document.getElementById("gunler").value
  guncelle()
}

guncelle()
</script>

</body>
</html>
